# ==============================================================================
# Multi-Agent AI Data Analyst - Git Ignore Rules
# ==============================================================================

# --- Python Bytecode & Cache ---
__pycache__/
*.py[cod]
*$py.class
.pytest_cache/
.mypy_cache/
.ruff_cache/
.ipynb_checkpoints/

# --- Virtual Environments ---
.venv/
venv/
env/
ENV/
dist/
build/
*.egg-info/
.eggs/

# --- IDE & Editor Configurations ---
.vscode/
.idea/
*.suo
*.ntvs*
*.njsproj
*.sln
*.swp
.project
.pydevproject
.settings/

# --- Local Environment & Credentials ---
.env
.env.local
.env.*.local
*.pem
*.key
credentials.json

# --- Workspace Outputs (Keep directory structure, ignore data/reports/logs) ---
workspace/uploads/*
!workspace/uploads/.gitkeep

workspace/cleaned/*
!workspace/cleaned/.gitkeep

workspace/processed/*
!workspace/processed/.gitkeep

workspace/plots/*
!workspace/plots/.gitkeep

workspace/reports/*
!workspace/reports/.gitkeep

workspace/models/*
!workspace/models/.gitkeep

workspace/logs/*
!workspace/logs/.gitkeep

# --- OS System Files ---
Thumbs.db
ehthumbs.db
Desktop.ini
.DS_Store
