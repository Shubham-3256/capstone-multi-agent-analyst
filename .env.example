# ==============================================================================
# Multi-Agent AI Data Analyst - Environment Variables Template
# ==============================================================================

# --- LLM Provider API Keys ---
# Add your API keys below (keep them secret and never check .env into source control)
OPENAI_API_KEY=your_openai_api_key_here
GEMINI_API_KEY=your_gemini_api_key_here
ANTHROPIC_API_KEY=your_anthropic_api_key_here

# --- LLM Model Setup ---
MODEL_NAME=gpt-4o
TEMPERATURE=0.0
MAX_TOKENS=4096

# --- Database Connection ---
DATABASE_URL=sqlite:///./workspace/data.db

# --- Cache and Workspaces Directories ---
WORKSPACE_DIR=./workspace
CACHE_DIR=./workspace/cache
REPORT_OUTPUT_DIR=./workspace/reports
MODEL_DIR=./workspace/models
UPLOAD_DIR=./workspace/uploads

# --- Application Logging ---
LOG_LEVEL=INFO

# --- Services Binding Configurations ---
API_HOST=0.0.0.0
API_PORT=8000
STREAMLIT_PORT=8501
